<Window
    x:Class="UniqueRankList.View.LicenseRequestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniqueRankList.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LicenseRequestWindow"
    Width="500"
    Height="300"
    Background="#0B0B0B"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>


        <!--  Sol Form Alanı  -->
        <StackPanel Margin="50" VerticalAlignment="Center">

            <TextBlock
                Margin="0,0,0,10"
                FontSize="24"
                FontWeight="Bold"
                Foreground="Gold"
                Text="🛡️ LİSANS TALEP FORMU" />
            <TextBlock
                Margin="0,0,0,5"
                Foreground="Red"
                Text="*Uygulamaya erişmek için Lisans Verisini geliştiriciye gönderiniz." />

            <!--  Ad Soyad  -->
            <TextBlock
                Margin="0,10,0,5"
                Foreground="White"
                Text="Lisans Verisi :" />
            <TextBox
                Padding="8"
                Background="#1E1E1E"
                BorderBrush="Gray"
                FontSize="12"
                Foreground="White"
                IsReadOnly="True"
                MaxLines="2"
                Text="{Binding BiosData}" />

        </StackPanel>
    </Grid>
</Window>
