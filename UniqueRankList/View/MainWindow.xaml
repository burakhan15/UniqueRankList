            </Grid>
            <DataGrid
                Grid.Row="5"
                AlternatingRowBackground="#0D1425"
                AutoGenerateColumns="False"
                Background="#0B1A35"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                FontSize="14"
                Foreground="White"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#2C3E72"
                IsReadOnly="True"
                ItemsSource="{Binding UniqueList}"
                RowBackground="#121B2D"
                VerticalGridLinesBrush="#2C3E72">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0D2A63" />
                        <Setter Property="Foreground" Value="#FFC000" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#20356B" />
                        <Setter Property="Padding" Value="5,10" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Resources>
                    <Style x:Key="CenteredTextStyle" TargetType="TextBlock">
                        <Setter Property="Margin" Value="10" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Unique}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Unique" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding SpawnTime}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Ortaya Çıkma" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding KillTime}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Kesilme" />
                    <DataGridTemplateColumn Width="150" Header="Öldüren">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,5,0"
                                        Source="{Binding KillerIcon}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        Foreground="LightBlue"
                                        Text="{Binding Killer}">
                                        <!--  Altı çizilen metin genelde link gibi görünür  -->

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextDecorations" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="TextDecorations">
                                                            <Setter.Value>
                                                                <TextDecorationCollection>
                                                                    <TextDecoration Location="Underline" />
                                                                </TextDecorationCollection>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                        <TextBlock.InputBindings>
                                            <MouseBinding
                                                Command="{Binding DataContext.KillerClickCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Gesture="LeftClick" />
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Region}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Bölge" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="6" Orientation="Horizontal">
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontSize="12"
                    Foreground="White"
                    Text="Son Güncelleme : " />
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontSize="12"
                    Foreground="White"
                    Text="{Binding LastUpdate}" />
            </StackPanel>
            <TextBlock
                Grid.Row="7"
                Margin="0,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="12"
                Foreground="White"
