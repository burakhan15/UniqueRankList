<Window
    x:Class="UniqueRankList.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniqueRankList"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    Title="Anlık Unique Verileri"
    Width="950"
    Height="850"
    Background="#FF1E1E1E"
    Foreground="White"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border BorderBrush="#2C3E72" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <Border
                Background="Black"
                BorderBrush="#2C3E72"
                BorderThickness="1"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="Yellow"
                        Text="ANLIK UNIQUE VERİLERİ" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="30"
                            Height="30"
                            Click="Button_Click"
                            Cursor="Hand"
                            ToolTip="Minimize">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="{TemplateBinding Background}">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="━" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Gray" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Width="30"
                            Height="30"
                            Command="{Binding CloseCommand}"
                            CommandParameter="Close"
                            Cursor="Hand"
                            ToolTip="Close">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="{TemplateBinding Background}">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="✕" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Red" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                    </StackPanel>
                </Grid>

            </Border>


            <StackPanel
                Grid.Row="1"
                Margin="10"
                Orientation="Horizontal">
                <!--  Başlık  -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="White"
                        Text="Ülke Seçiniz : " />
                    <ComboBox
                        Width="250"
                        Height="30"
                        Margin="10,0,0,0"
                        Padding="5,2"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        BorderThickness="1"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#FFC000"
                        ItemsSource="{Binding Countries}"
                        SelectedItem="{Binding SelectedCountry, Mode=TwoWay}">

                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton
                                                    x:Name="ToggleButton"
                                                    Grid.Column="2"
                                                    Background="#20356B"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    ClickMode="Press"
                                                    Focusable="false"
                                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                    <ContentPresenter />
                                                </ToggleButton>
                                                <ContentPresenter
                                                    Name="ContentSite"
                                                    Margin="6,3,25,3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                    IsHitTestVisible="False" />
                                                <Popup
                                                    Name="Popup"
                                                    AllowsTransparency="True"
                                                    Focusable="False"
                                                    IsOpen="{TemplateBinding IsDropDownOpen}"
                                                    Placement="Bottom"
                                                    PopupAnimation="Slide">
                                                    <Grid
                                                        Name="DropDown"
                                                        MinWidth="{TemplateBinding ActualWidth}"
                                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                        SnapsToDevicePixels="True">
                                                        <Border
                                                            x:Name="DropDownBorder"
                                                            Background="#20356B"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" />
                                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#0D2A63" />
                                <Setter Property="Foreground" Value="#FFC000" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="18" />
                                <Setter Property="Padding" Value="5,2" />
                                <Setter Property="Height" Value="30" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#111111" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#20356B" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <Image
                        Height="50"
                        Margin="400,0,0,0"
                        HorizontalAlignment="Right"
                        Source="/Assets/Icons/logo.png" />
                </StackPanel>
            </StackPanel>
            <StackPanel
                Grid.Row="2"
                Margin="10"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="Lütfen Sunucu Seçin : " />
                <ComboBox
                    Width="150"
                    Height="30"
                    Margin="10,0,0,0"
                    Padding="5,2"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="1"
                    DisplayMemberPath="Server"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#FFC000"
                    ItemsSource="{Binding ServerList}"
                    SelectedItem="{Binding SelectedServer, Mode=TwoWay}">

                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton
                                                x:Name="ToggleButton"
                                                Grid.Column="2"
                                                Background="#20356B"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                ClickMode="Press"
                                                Focusable="false"
                                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                <ContentPresenter />
                                            </ToggleButton>
                                            <ContentPresenter
                                                Name="ContentSite"
                                                Margin="6,3,25,3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Content="{TemplateBinding SelectionBoxItem}"
                                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                IsHitTestVisible="False" />
                                            <Popup
                                                Name="Popup"
                                                AllowsTransparency="True"
                                                Focusable="False"
                                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                                Placement="Bottom"
                                                PopupAnimation="Slide">
                                                <Grid
                                                    Name="DropDown"
                                                    MinWidth="{TemplateBinding ActualWidth}"
                                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                    SnapsToDevicePixels="True">
                                                    <Border
                                                        x:Name="DropDownBorder"
                                                        Background="#20356B"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1" />
                                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                    </ScrollViewer>
                                                </Grid>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>

                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#0D2A63" />
                            <Setter Property="Foreground" Value="#FFC000" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="FontSize" Value="18" />
                            <Setter Property="Padding" Value="5,2" />
                            <Setter Property="Height" Value="30" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#111111" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20356B" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button
                    Width="250"
                    Height="30"
                    Margin="10,0,0,0"
                    Padding="5,2"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#20356B"
                    BorderBrush="#20356B"
                    Command="{Binding ToggleOverlayCommand}"
                    CommandParameter="Info"
                    Content="Bilgi Penceresini Aç/Kapa"
                    Cursor="Hand"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#FFC000">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="0">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                RecognizesAccessKey="True" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#111111" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#0D2A63" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Grid Margin="10,0,0,0">
                    <Grid.Resources>
                        <Style x:Key="PopupStyle" TargetType="Popup">
                            <Setter Property="IsOpen" Value="False" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=InfoImage}" Value="True">
                                    <Setter Property="IsOpen" Value="True" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Resources>

                    <ToggleButton
                        x:Name="InfoToggleButton"
                        Width="35"
                        Height="35"
                        Margin="10"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Cursor="Hand">
                        <Image
                            Width="25"
                            Height="25"
                            Source="/Assets/Icons/info.png" />
                    </ToggleButton>

                    <Popup
                        AllowsTransparency="True"
                        IsOpen="{Binding IsChecked, ElementName=InfoToggleButton}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=InfoToggleButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        Style="{StaticResource PopupStyle}">

                        <Grid Background="#0B1A35">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Padding="5"
                                    Background="#4472C4"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Unique" />
                                <TextBlock
                                    Grid.Column="1"
                                    Padding="5"
                                    Background="#4472C4"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Saat 1" />
                                <TextBlock
                                    Grid.Column="2"
                                    Padding="5"
                                    Background="#4472C4"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Saat 2" />
                                <TextBlock
                                    Grid.Column="3"
                                    Padding="5"
                                    Background="#4472C4"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Saat 3" />
                                <TextBlock
                                    Grid.Column="4"
                                    Padding="5"
                                    Background="#4472C4"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="Saat 4" />
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding SpawnList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Column="0"
                                                Padding="5"
                                                Text="{Binding UniqueName}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Padding="5"
                                                Text="{Binding ConvertedSpawnTimes[0]}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Padding="5"
                                                Text="{Binding ConvertedSpawnTimes[1]}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                Padding="5"
                                                Text="{Binding ConvertedSpawnTimes[2]}" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Padding="5"
                                                Text="{Binding ConvertedSpawnTimes[3]}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                    </Popup>
                </Grid>
            </StackPanel>
            <Grid Grid.Row="3" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Tiger Girl : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/tigergirl.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding TigerGirl}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>

                </Border>

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Cerberus : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/cerberus.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding Cerberus}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="0"
                    Grid.Column="2"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Captain Ivy : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/captainivy.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding CaptainIvy}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>


                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Uruchi : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/uruchi.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding Uruchi}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Isyutaru : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/isyutaru.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding Isyutaru}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Row="1"
                    Grid.Column="2"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Lord Yarkan : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/lordyarkan.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding LordYarkan}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Row="2"
                    Grid.Column="0"
                    BorderBrush="#2C3E72"
                    BorderThickness="1">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Demon Shaitan : "
                            TextDecorations="Underline">
                            <TextBlock.ToolTip>
                                <ToolTip Placement="Mouse">
                                    <Image Width="300" Source="/Assets/Icons/demonshaitan.png" />
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Yellow"
                            Text="{Binding DemonShaitan}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="önce kesildi." />
                    </StackPanel>
                </Border>
            </Grid>
            <DataGrid
                Grid.Row="4"
                AlternatingRowBackground="#0D1425"
                AutoGenerateColumns="False"
                Background="#0B1A35"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                FontSize="14"
                Foreground="White"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#2C3E72"
                IsReadOnly="True"
                ItemsSource="{Binding UniqueList}"
                RowBackground="#121B2D"
                VerticalGridLinesBrush="#2C3E72">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0D2A63" />
                        <Setter Property="Foreground" Value="#FFC000" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#20356B" />
                        <Setter Property="Padding" Value="5,10" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Resources>
                    <Style x:Key="CenteredTextStyle" TargetType="TextBlock">
                        <Setter Property="Margin" Value="10" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Unique}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Unique" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding SpawnTime}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Ortaya Çıkma" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding KillTime}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Kesilme" />
                    <DataGridTemplateColumn Width="150" Header="Öldüren">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,5,0"
                                        Source="{Binding KillerIcon}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        Foreground="LightBlue"
                                        Text="{Binding Killer}">
                                        <!--  Altı çizilen metin genelde link gibi görünür  -->

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextDecorations" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="TextDecorations">
                                                            <Setter.Value>
                                                                <TextDecorationCollection>
                                                                    <TextDecoration Location="Underline" />
                                                                </TextDecorationCollection>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                        <TextBlock.InputBindings>
                                            <MouseBinding
                                                Command="{Binding DataContext.KillerClickCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Gesture="LeftClick" />
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Region}"
                        ElementStyle="{StaticResource CenteredTextStyle}"
                        Header="Bölge" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="5" Orientation="Horizontal">
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontSize="12"
                    Foreground="White"
                    Text="Son Güncelleme : " />
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontSize="12"
                    Foreground="White"
                    Text="{Binding LastUpdate}" />
            </StackPanel>
            <TextBlock
                Grid.Row="5"
                Margin="0,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="12"
                Foreground="White"
                Text="Developed by Hecate" />

            <tb:TaskbarIcon
                x:Name="MyNotifyIcon"
                IconSource="/Assets/Logos/Logo.ico"
                ToolTipText="Uygulama Açıklaması">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Click="Show_Click" Header="Göster" />
                        <MenuItem Click="Exit_Click" Header="Çıkış" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </Grid>
    </Border>

</Window>
